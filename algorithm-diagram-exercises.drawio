        <mxCell id="OS1mSw7-EyHDvwXKFEWj-69" parent="OS1mSw7-EyHDvwXKFEWj-1" style="rhombus;whiteSpace=wrap;html=1;rounded=1;labelBackgroundColor=none;fillColor=#F08E81;strokeColor=#FFFFFF;fontColor=#1A1A1A;" value="Q &amp;gt; 500" vertex="1">
