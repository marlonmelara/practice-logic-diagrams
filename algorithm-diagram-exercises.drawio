        <mxCell id="topIDf8pgiBtBCV1BCpL-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=1;labelBackgroundColor=none;fontColor=#1A1A1A;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Ejercicio 6&lt;/h1&gt;&lt;p&gt;Una casa de video juegos otorga un descuento dependiendo del importe de la&amp;nbsp; compra realizada según los siguientes valores:&amp;nbsp;&lt;/p&gt;&lt;p&gt;• Si el importe es menor a ARS 1000, no hay descuento.&amp;nbsp;&lt;/p&gt;&lt;p&gt;• Si el importe es ARS 1000&amp;nbsp; o más pero menor a ARS 5000, aplica un&amp;nbsp; descuento del 10%.&amp;nbsp;&lt;/p&gt;&lt;p&gt;• Si el importe es ARS 5000 o más, aplica un descuento del 18%.&amp;nbsp;&lt;/p&gt;&lt;p&gt;Hacer un programa para ingresar un importe de venta y luego muestre por&amp;nbsp; pantalla el importe final con el descuento que corresponda.&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="440" width="300" x="3890" y="40" as="geometry" />
        </mxCell>
        <mxCell id="topIDf8pgiBtBCV1BCpL-2" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=1;labelBackgroundColor=none;fontColor=#1A1A1A;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Ejercicio 7&lt;/h1&gt;&lt;p&gt;Hacer un programa para ingresar cuatro números distintos y luego mostrar por pantalla el mayor de ellos.&lt;/p&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="300" x="4960" y="40" as="geometry" />
        </mxCell>
        <mxCell id="topIDf8pgiBtBCV1BCpL-3" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=1;labelBackgroundColor=none;fontColor=#1A1A1A;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Ejercicio 8&lt;/h1&gt;&lt;p&gt;Hacer un programa para ingresar cuatro números distintos y luego mostrar por&amp;nbsp; pantalla el menor de ellos.&lt;/p&gt;" vertex="1">
